# ============================================================
# QUALICONSIG API - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no GitHub
# ============================================================

# === SUPABASE ===
# Encontre em: https://app.supabase.com → Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (NÃO é a anon key)

# === JWT ===
# Gere uma string aleatória forte. Ex: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UMA_CHAVE_FORTE_AQUI_64_CARACTERES_MINIMO

# === CORS ===
# URLs que podem chamar a API (GitHub Pages + seu domínio)
ALLOWED_ORIGINS=https://SEU_USUARIO.github.io,https://www.qualiconsig.com.br

# === PORTA ===
PORT=3001
